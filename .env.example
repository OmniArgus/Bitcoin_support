# Get this from @BotFather on Telegram (https://t.me/BotFather)
BOT_TOKEN=123456:ABC-your-token-here

# Which coin to track (CoinGecko id) and currency
COIN_ID=bitcoin
VS_CURRENCY=usd

# How often to check the price, in seconds
POLL_SECONDS=60

# Default price move (in VS_CURRENCY) that triggers a notification
THRESHOLD=30

# Where to keep subscriber/state data
STATE_FILE=state.json
